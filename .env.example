# =============================================================
# Laundrix — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# Never commit your real .env file to Git.
#
# Usage:
#   cp .env.example .env
# =============================================================

# --- Database ---
# PostgreSQL connection string (e.g. Neon, Supabase, or local)
DATABASE_URL="postgresql://neondb_owner:npg_sxvIPqac2pF9@ep-holy-rain-ahxnps1c-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# --- Authentication ---
# Secret key used to sign JWT tokens — must be a long, random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="4f92c813a8d46b78e5f29c1d0a3b68f54c7d91e23f8b0d4c1a5e9d7f3b6c2a8f"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="7d1e8c9b2f4a56d3c0e1b9a7f8d2c4b6e5a3d1c9f8b0e7a2c4d6f9b1e3a5d8c7"
JWT_REFRESH_EXPIRES_IN="7d"

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Next.js Public Variables ---
# Base URL of your Express backend — used by the frontend to call the API.
#
# IMPORTANT: Since this project runs Next.js + Express on the SAME server (port 3000),
# use a RELATIVE path "/api" in development so it always resolves correctly.
# Only set a full URL for a separately-deployed backend (e.g. Railway/Render).
#
# Local development (recommended):
NEXT_PUBLIC_API_URL="/api"
# Production with separate backend:
# NEXT_PUBLIC_API_URL="https://your-backend.railway.app/api"

# --- Social Login (Optional) ---
# Google OAuth — get from https://console.cloud.google.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"

# Facebook OAuth — get from https://developers.facebook.com
NEXT_PUBLIC_FACEBOOK_APP_ID="your-facebook-app-id"
