# =============================================================
# LAVO — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in your actual values.
# Never commit your real .env file to Git.
#
# Usage:
#   cp .env.example .env
# =============================================================

# --- Database ---
# PostgreSQL connection string (e.g. Neon, Supabase, or local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# --- Authentication ---
# Secret key used to sign JWT tokens — must be a long random string
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Next.js Public API URL ---
# The base URL of your Express backend (used by the frontend)
NEXT_PUBLIC_API_URL="http://localhost:5000/api"
