// Review, Support & System Configuration Models

model Review {
  id             String   @id @default(uuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id])
  rating         Float
  title          String?
  review         String
  serviceRating  Float?
  pickupRating   Float?
  deliveryRating Float?
  qualityRating  Float?
  status         String   @default("PUBLISHED")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  replies   ReviewReply[]
  images    ReviewImage[]
  reactions ReviewReaction[]
  reports   ReviewReport[]
}

model ReviewReply {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  adminId   String? // Maps to User
  reply     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReviewImage {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  imageUrl  String
  createdAt DateTime @default(now())
}

model ReviewReaction {
  id           String   @id @default(uuid())
  reviewId     String
  review       Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId       String // Maps to User
  reactionType String // Helpful, Like
  createdAt    DateTime @default(now())
}

model ReviewReport {
  id         String   @id @default(uuid())
  reviewId   String
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reportedBy String // Maps to User
  reason     String
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
}

model SupportTicket {
  id           String         @id @default(uuid())
  ticketNumber String         @unique
  customerId   String
  customer     Customer       @relation(fields: [customerId], references: [id])
  categoryId   String
  category     TicketCategory @relation(fields: [categoryId], references: [id])
  subject      String
  priority     String         @default("NORMAL")
  status       String         @default("OPEN")
  assignedTo   String? // Maps to User (Admin/Support)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  messages    TicketMessage[]
  attachments TicketAttachment[]
  histories   TicketStatusHistory[]
}

model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String // Maps to User
  message   String
  createdAt DateTime      @default(now())
}

model TicketAttachment {
  id         String        @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileUrl    String
  fileType   String
  uploadedBy String?
  createdAt  DateTime      @default(now())
}

model TicketCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())

  tickets SupportTicket[]
}

model TicketStatusHistory {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  status    String
  changedBy String?
  remarks   String?
  createdAt DateTime      @default(now())
}

model FAQ {
  id           String   @id @default(uuid())
  question     String
  answer       String
  category     String
  displayOrder Int      @default(0)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Announcement {
  id         String    @id @default(uuid())
  title      String
  content    String
  targetType String // ALL, CUSTOMER, VENDOR, BRANCH
  startDate  DateTime
  endDate    DateTime?
  status     String    @default("ACTIVE")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model SystemSetting {
  id           String   @id @default(uuid())
  settingKey   String   @unique
  settingValue String
  category     String
  description  String?
  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BusinessHour {
  id          String   @id @default(uuid())
  day         String
  openingTime String
  closingTime String
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaxRule {
  id            String   @id @default(uuid())
  taxName       String
  taxPercentage Float
  country       String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DeliveryChargeRule {
  id             String   @id @default(uuid())
  ruleName       String
  baseCharge     Float
  distanceCharge Float
  weightCharge   Float
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FeatureFlag {
  id          String   @id @default(uuid())
  featureName String   @unique
  isEnabled   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DashboardWidget {
  id         String   @id @default(uuid())
  widgetName String
  widgetType String
  position   Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
