// Laundry Service & Pricing Models

model LaundryService {
  id           String   @id @default(uuid())
  serviceCode  String   @unique
  serviceName  String
  description  String?
  icon         String?
  status       String   @default("ACTIVE")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ServiceCategory {
  id           String   @id @default(uuid())
  name         String   @unique
  icon         String?
  description  String?
  status       String   @default("ACTIVE")
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GarmentCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  icon        String?
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  garmentTypes GarmentType[]
}

model GarmentType {
  id         String          @id @default(uuid())
  categoryId String
  category   GarmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name       String
  icon       String?
  unitType   String
  baseWeight Float?
  status     String          @default("ACTIVE")
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  services   Service[]
  careLabels CareLabel[]
  orderItems OrderItem[]
}

model Service {
  id                String      @id @default(uuid())
  serviceCategoryId String // Maps to ServiceCategory
  garmentTypeId     String
  garmentType       GarmentType @relation(fields: [garmentTypeId], references: [id], onDelete: Cascade)
  serviceName       String
  description       String?
  basePrice         Float       @default(0.0)
  estimatedTime     String?
  status            String      @default("ACTIVE")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  variants       ServiceVariant[]
  options        ServiceOption[]
  addons         ServiceAddon[]
  pricings       ServicePricing[]
  zonePricings   ZonePricing[]
  branchPricings BranchPricing[]
  vendorPricings VendorPricing[]
  durations      ServiceDuration[]
  taxes          ServiceTax[]
  discounts      ServiceDiscount[]
  availabilities ServiceAvailability[]
  inventoryReqs  ServiceInventoryRequirement[]
  instructions   ServiceInstruction[]
  analytics      ServiceAnalytics[]
  priceHistories PriceHistory[]
  orderItems     OrderItem[]
}

model ServiceVariant {
  id            String   @id @default(uuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  variantName   String
  description   String?
  price         Float
  estimatedTime String?
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceOption {
  id         String   @id @default(uuid())
  serviceId  String
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  optionName String
  optionType String
  price      Float
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ServiceAddon {
  id          String   @id @default(uuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  addonName   String
  price       Float
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServicePricing {
  id            String    @id @default(uuid())
  serviceId     String
  service       Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  garmentTypeId String // Maps to GarmentType
  basePrice     Float
  unit          String
  currency      String    @default("BDT")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ZonePricing {
  id             String   @id @default(uuid())
  zoneId         String // Maps to Zone
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price          Float
  pickupCharge   Float    @default(0.0)
  deliveryCharge Float    @default(0.0)
  expressCharge  Float    @default(0.0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BranchPricing {
  id        String   @id @default(uuid())
  branchId  String // Maps to Branch
  serviceId String
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  price     Float
  discount  Float    @default(0.0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VendorPricing {
  id             String   @id @default(uuid())
  vendorId       String // Maps to Vendor
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  processingCost Float
  vendorRate     Float
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ServiceDuration {
  id             String   @id @default(uuid())
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  estimatedHours Float
  estimatedDays  Float
  expressHours   Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ServiceTax {
  id            String   @id @default(uuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  taxName       String
  taxPercentage Float
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceDiscount {
  id            String   @id @default(uuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  discountType  String
  discountValue Float
  startDate     DateTime
  endDate       DateTime
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceAvailability {
  id          String   @id @default(uuid())
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  branchId    String? // Maps to Branch
  vendorId    String? // Maps to Vendor
  zoneId      String? // Maps to Zone
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ServiceInventoryRequirement {
  id            String   @id @default(uuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  inventoryItem String
  quantity      Float
  unit          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ServiceInstruction {
  id               String   @id @default(uuid())
  serviceId        String
  service          Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  instructionTitle String
  instruction      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model CareLabel {
  id            String      @id @default(uuid())
  garmentTypeId String
  garmentType   GarmentType @relation(fields: [garmentTypeId], references: [id], onDelete: Cascade)
  labelName     String
  symbol        String?
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ServiceAnalytics {
  id                    String   @id @default(uuid())
  serviceId             String
  service               Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  totalOrders           Int      @default(0)
  totalRevenue          Float    @default(0.0)
  averageCompletionTime Float    @default(0.0)
  averageRating         Float    @default(0.0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PriceHistory {
  id            String   @id @default(uuid())
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  oldPrice      Float
  newPrice      Float
  changedBy     String? // Maps to Admin User
  effectiveDate DateTime
  reason        String?
  createdAt     DateTime @default(now())
}

// --- From cms.prisma ---
// Content Management System (CMS) Models

model CmsPage {
  id          String       @id @default(uuid())
  slug        String       @unique // e.g., "home", "services", "pricing"
  title       String
  description String?
  status      String       @default("PUBLISHED") // PUBLISHED, DRAFT
  sections    CmsSection[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model CmsSection {
  id          String           @id @default(uuid())
  pageId      String
  page        CmsPage          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  sectionKey  String           // e.g., "hero", "process", "features"
  title       String?
  subtitle    String?
  content     String?          @db.Text
  image       String?
  displayOrder Int             @default(0)
  items       CmsContentItem[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([pageId, sectionKey])
}

model CmsContentItem {
  id          String     @id @default(uuid())
  sectionId   String
  section     CmsSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title       String?
  subtitle    String?
  content     String?    @db.Text
  icon        String?
  image       String?
  linkUrl     String?
  linkText    String?
  displayOrder Int       @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

