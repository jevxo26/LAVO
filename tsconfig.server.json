{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "outDir": "dist",
    "noEmit": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "isolatedModules": false,
    "moduleResolution": "node"
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", "scratch", "dist"]
}
